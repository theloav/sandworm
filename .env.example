# SANDWORM configuration — copy to .env and adjust. Defaults are SAFE:
# detonation is off and the simulated network is assumed.

# --- Work dir (runs, samples, audit log) ---
SANDWORM_WORK_DIR=.sandworm

# --- Isolation / safety (load-bearing) ---
# Operator opt-in for the dynamic lane. Even when true, detonation still requires
# the isolation marker + no real network (see core/isolation.py).
SANDWORM_ALLOW_DETONATION=false
# Set this INSIDE the detonation container/VM image only — proves isolation.
# SANDWORM_ISOLATED=1
SANDWORM_SIMNET_HOST=10.0.0.1

# --- Encrypted-at-rest sample store ---
SANDWORM_SAMPLE_PASSWORD=infected

# --- Graph backend (optional; in-memory fallback if unset) ---
# SANDWORM_NEO4J_URI=bolt://localhost:7687
# SANDWORM_NEO4J_USER=neo4j
# SANDWORM_NEO4J_PASSWORD=changeme

# --- LLM copilot (default: offline mock, no secret needed) ---
SANDWORM_LLM_PROVIDER=mock
SANDWORM_LLM_MODEL=claude-opus-4-8
# SANDWORM_LLM_API_KEY=
